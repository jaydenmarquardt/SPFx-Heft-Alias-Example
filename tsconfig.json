{
  "extends": "./node_modules/@microsoft/spfx-web-build-rig/profiles/default/tsconfig-base.json",
  "compilerOptions": {
    "target": "es2017",
    "module": "esnext",
    "baseUrl": "./src",
    "paths": {
      "@components/*": ["components/*"],

      "@webparts/*": ["webparts/*"]
    },
    "lib": [
      "dom",
      "es5",
      "es2015.core",
      "es2015.collection",
      "es2015.iterable",
      "es2015.promise",
      "es2015.proxy",
      "es2017.string",
      "es2017.intl"
    ]
  },
  "exclude": ["lib", "dist", "temp", "node_modules"]
}
